<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Form view -->
    <record id="view_library_author_form" model="ir.ui.view">
        <field name="name">library.author.form</field>
        <field name="model">library.author</field>
        <field name="arch" type="xml">
            <form string="Autore">
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Nome autore..."/>
                        </h1>
                    </div>
                    <group>
                        <field name="birth_date"/>
                        <field name="book_count"/>
                    </group>
                    <notebook>
                        <page string="Biografia">
                            <field name="bio" placeholder="Biografia..."/>
                        </page>
                        <page string="Libri" attrs="{'invisible': [('book_count', '=', 0)]}">
                            <field name="book_ids">
                                <tree>
                                    <field name="title"/>
                                    <field name="isbn"/>
                                    <field name="state"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Tree view -->
    <record id="view_library_author_tree" model="ir.ui.view">
        <field name="name">library.author.tree</field>
        <field name="model">library.author</field>
        <field name="arch" type="xml">
            <tree string="Autori">
                <field name="name"/>
                <field name="birth_date"/>
                <field name="book_count"/>
            </tree>
        </field>
    </record>

    <!-- Action -->
    <record id="action_library_author" model="ir.actions.act_window">
        <field name="name">Autori</field>
        <field name="res_model">library.author</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>
